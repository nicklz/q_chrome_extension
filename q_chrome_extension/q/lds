#!/usr/bin/env bash
# =====================================================================================
# lds: List & Detail Summary — gitignore/dockerignore-aware file listing
# =====================================================================================
# Behavior:
# - Lists files using .gitignore (and standard git excludes) when inside a git repo.
# - Also applies .dockerignore exclusions if present (best-effort, common patterns).
# - Always hard-excludes obvious junk: node_modules, .git, dist/build caches, etc.
# - Prints one line per file:
#     ✅ <path> | <KB> KB
#
# Args:
# - lds
#     → prints absolute paths
# - lds a
#     → strips prefix "/home/nexus/sites/waypoints/nexus/scripts" from paths if present
#
# Notes:
# - Date and permissions have been removed as requested.
# =====================================================================================

set -u

# --- Config ---
HARD_EXCLUDES_REGEX='(^|/)(node_modules|\.git|\.svn|\.hg|\.DS_Store|dist|build|coverage|\.next|\.cache)(/|$)'
STRIP_PREFIX="/home/nexus/sites/waypoints/nexus/scripts"

# --- Helpers ---
have_cmd() { command -v "$1" >/dev/null 2>&1; }

abs_path() {
  if have_cmd realpath; then
    realpath "$1" 2>/dev/null && return 0
  fi
  if have_cmd python3; then
    python3 - <<'PY' "$1" 2>/dev/null && return 0
import os,sys
print(os.path.realpath(sys.argv[1]))
PY
  fi
  printf "%s/%s\n" "$PWD" "${1#./}"
}

stat_kb() {
  local f="$1"
  if have_cmd stat && stat -c '%s' "$f" >/dev/null 2>&1; then
    local bytes
    bytes="$(stat -c '%s' "$f" 2>/dev/null || echo "")"
    if [[ "$bytes" =~ ^[0-9]+$ ]]; then
      printf "%s\n" $(( (bytes + 1023) / 1024 ))
    else
      printf "?\n"
    fi
    return
  fi
  if have_cmd stat && stat -f '%z' "$f" >/dev/null 2>&1; then
    local bytes
    bytes="$(stat -f '%z' "$f" 2>/dev/null || echo "")"
    if [[ "$bytes" =~ ^[0-9]+$ ]]; then
      printf "%s\n" $(( (bytes + 1023) / 1024 ))
    else
      printf "?\n"
    fi
    return
  fi
  printf "?\n"
}

is_git_repo() {
  have_cmd git && git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

dockerignore_to_grepv() {
  local f=".dockerignore"
  [ -f "$f" ] || return 1
  local rx=""
  while IFS= read -r line; do
    line="${line%$'\r'}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue
    [[ "$line" == \#* ]] && continue
    [[ "$line" == "!"* ]] && continue
    line="${line#./}"
    local part="$line"
    part="$(printf "%s" "$part" | sed -e 's/[.[\^$+(){}|\\]/\\&/g')"
    part="$(printf "%s" "$part" | sed -e 's/\*/.*/g' -e 's/\?/./g')"
    part="(^|/)$part(/|$)"
    rx="${rx:+$rx|}$part"
  done < "$f"
  [ -n "$rx" ] || return 1
  printf "%s\n" "$rx"
}

emit_files_null_delim() {
  if is_git_repo; then
    git ls-files -z -co --exclude-standard 2>/dev/null
    return
  fi
  find . \
    -type d \( -name node_modules -o -name .git -o -name dist -o -name build -o -name coverage -o -name .next -o -name .cache \) -prune -false \
    -o -type f -print0 2>/dev/null
}

main() {
  local strip_mode="false"
  if [ "${1:-}" = "a" ]; then
    strip_mode="true"
  fi

  local docker_rx=""
  [ -f ".dockerignore" ] && docker_rx="$(dockerignore_to_grepv 2>/dev/null || true)"

  emit_files_null_delim \
    | while IFS= read -r -d '' f; do
        f="${f#./}"
        [ -z "$f" ] && continue
        printf "%s\n" "$f" | grep -Eq "$HARD_EXCLUDES_REGEX" && continue
        if [ -n "$docker_rx" ] && printf "%s\n" "$f" | grep -Eq "$docker_rx"; then
          continue
        fi
        printf "%s\0" "$f"
      done \
    | sort -z \
    | while IFS= read -r -d '' f; do
        local ap kb out
        ap="$(abs_path "./$f")"
        if [ "$strip_mode" = "true" ] && [[ "$ap" == "$STRIP_PREFIX"* ]]; then
          ap="${ap#$STRIP_PREFIX}"
          ap="${ap#/}"
        fi
        kb="$(stat_kb "./$f")"
        printf "✅ %s | %s KB\n" "$ap" "$kb"
      done
}

main "$@"
